# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
FLASK_ENV=production

# Optional: sets the password for the auto-created first-run 'admin' account.
# Leave unset to have the app generate a random one-time password instead
# (it is never logged) — then use "Forgot password" to choose your own.
DEFAULT_ADMIN_PASSWORD=

# ── MySQL (XAMPP default values shown) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jdk_factory
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
